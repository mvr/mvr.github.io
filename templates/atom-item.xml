  <entry>
    <title>$title$</title>
    <link href="$url$" />
    <id>$url$</id>
    $if(published)$
    <published>$published$</published>
    $endif$
    <updated>$updated$</updated>
    <author>
      <name>$authorName$</name>
      $if(authorEmail)$
      <email>$authorEmail$</email>
      $endif$
    </author>
    <summary type="html"><![CDATA[$description$<p><a href="$url$">&gt; Read Post</a></p>]]></summary>
  </entry>
